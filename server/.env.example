# cards-api env (copy to .env)

# App
NODE_ENV=development
PORT=3005
APP_URL=http://localhost:8000
DEFAULT_THEME=modern

# Database — Yandex Managed PostgreSQL (обязательный SSL + CA)
# Порт 6432 = pg_bouncer (pooler), 5432 = прямое подключение к мастеру.
DATABASE_URL=postgresql://cards_user:PASSWORD@rc1a-XXXXXXXX.mdb.yandexcloud.net:6432/cards?sslmode=verify-full
DB_CA_PATH=./yandex-root.crt

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=replace-with-32+-bytes-random-base64
JWT_TTL_SECONDS=604800

# Uploads
UPLOADS_DIR=./uploads
MAX_UPLOAD_MB=5

# Front origin (для CORS в dev — в prod same-origin, CORS не нужен)
CORS_ORIGIN=http://localhost:8000
