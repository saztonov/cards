# cards-api env (copy to .env for dev, load from Lockbox in prod)

# App
NODE_ENV=development
PORT=3005
APP_URL=http://localhost:8000
DEFAULT_THEME=modern

# Database (pg connection string)
DATABASE_URL=postgres://postgres:dev@localhost:5432/cards

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=replace-with-32+-bytes-random-base64
ACCESS_TTL_SECONDS=900
REFRESH_TTL_DAYS=30

# Uploads
UPLOADS_DIR=./uploads
MAX_UPLOAD_MB=5

# SMTP (nodemailer; для локалки можно указать Mailtrap или оставить фиктивным — письма пойдут в лог)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Cards <no-reply@cards.fvds.ru>"

# Front origin (для CORS в dev — в prod same-origin, CORS не нужен)
CORS_ORIGIN=http://localhost:8000

# Cookie
# В dev — false (http://). В prod — true.
COOKIE_SECURE=false
